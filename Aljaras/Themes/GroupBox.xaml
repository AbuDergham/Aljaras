    <Style x:Key="GroupBoxListView" TargetType="GroupBox">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Path
                            Height="8"
                            Margin="5,0"
                            Data="{StaticResource ListPathData}"
                            Fill="#252525"
                            Stretch="Uniform" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="{Binding}">
                            <Run Text=" -" />
                            <Run Text="{Binding Path=(extensions:Extensions.Carrier), RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type GroupBox}}}" />
                            <Run Text=" (" />
                            <Run Text="{Binding Path=(extensions:Extensions.Carrier2), RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type GroupBox}}}" />
                            <Run Text=" )" />
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>