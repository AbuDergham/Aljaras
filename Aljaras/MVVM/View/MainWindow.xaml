                            Command="{Binding ShutdownWindowCommand}"
                            Style="{DynamicResource TitleBarButton}" />
                    </StackPanel>

                </Grid>
            </Border>
            <!--#endregion  TitleBar-->

            <!--#region MonitoringBar-->
            <Border
                x:Name="g"
                Height="20"
                Background="#252525"
                DockPanel.Dock="Bottom"
                Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Path
                            Width="15"
                            Margin="0,0,0,-2"
                            Data="{StaticResource SystemTimePathData}"
                            Fill="White"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.SystemTime}" />
                        <Run Text="{Binding Global.SystemTime}" />
                    </TextBlock>
                    <Border
                        Margin="5,3"
                        BorderBrush="LightGray"
                        BorderThickness="1,0,0,0" />
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Path
                            Grid.Row="1"
                            Width="15"
                            Margin="0,0,0,-2"
                            Data="{StaticResource AlarmBellPathData}"
                            Fill="White"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.NextAlarm}" />
                        <Run Text="{Binding Global.CurrentAlarm}" />
                    </TextBlock>
                    <Border
                        Margin="5,3"
                        BorderBrush="LightGray"
                        BorderThickness="1,0,0,0" />
                    <TextBlock VerticalAlignment="Center" Foreground="White">
                        <Path
                            Grid.Row="2"
                            Height="15"
                            Margin="0,0,0,-2"
                            Data="{StaticResource TimeLeftPathData}"
                            Fill="White"
                            Stretch="Uniform" />
                        <Run Text="{Binding Global.AppLang.TimeLeft}" />
                        <Run Text="{Binding Global.ShowTimeLeft}" />
                    </TextBlock>
                    <Border
                        Margin="5,3"
                        BorderBrush="LightGray"
                        BorderThickness="1,0,0,0" />
                    <Button
                        Margin="5,0"
                        Command="{Binding ShowAboutMeViewCommand}"
                        Style="{StaticResource CopyrightButton}">
                        <TextBlock Margin="5,0">
                            <Run Text="© Mustafa AlKlieb, All rights reserved." />
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Border>
            <!--#endregion *** MonitoringBar ***-->

            <!--#region *** Main Menu ***-->
            <Border
                Width="48"
                HorizontalAlignment="Left"
                Background="#252525">
                <Border.Style>
                    <Style>
                        <Style.Triggers>
                            <EventTrigger RoutedEvent="Border.MouseEnter">
                                <EventTrigger.Actions>
                                    <BeginStoryboard Name="MyBeginStoryboard">
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Width)"
                                                To="145"
                                                Duration="0:0:.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Border.MouseLeave">
                                <EventTrigger.Actions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.Width)"
                                                To="48"
                                                Duration="0:0:.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger.Actions>
                            </EventTrigger>
                        </Style.Triggers>
