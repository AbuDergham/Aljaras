                            Margin="10,0,0,0"
                            FontFamily="Consolas"
                            FontSize="16"
                            Foreground="LightGray"
                            Text="{Binding Global.AppLang.Menu}" />
                    </StackPanel>
                    <TextBlock
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
