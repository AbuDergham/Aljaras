<UserControl
    x:Class="Aljaras.MVVM.View.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:extensions="clr-namespace:Aljaras"
    xmlns:local="clr-namespace:Aljaras.MVVM.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:Aljaras.MVVM.ViewModel"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="White"
    mc:Ignorable="d">
    <UserControl.DataContext>
        <viewmodel:SettingsViewModel />
    </UserControl.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Border
            Background="OldLace"
            BorderBrush="LightGray"
            BorderThickness="0,0,1,1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Path
                    Width="60"
                    Data="{StaticResource LanguagePath}"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Foreground="Black"
                    Text="{Binding Global.AppLang.Language}" />
                <ComboBox
                    Width="150"
                    HorizontalAlignment="Stretch"
                    FontSize="14"
                    ItemsSource="{Binding Lang}"
                    SelectedItem="{Binding UserSet.CurrentLang}" />
            </StackPanel>
        </Border>
        <Border
            Grid.Column="1"
            Background="LightYellow"
            BorderBrush="LightGray"
            BorderThickness="0,0,0,1">
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <Path
                    Width="50"
                    Data="{StaticResource EmergencyPath}"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Text="{Binding Global.AppLang.Emergency}" />
                <StackPanel
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,-53,-13"
                        HorizontalAlignment="Center"
                        Panel.ZIndex="10"
                        extensions:Extensions.Icon="M20.638,12.716986L12.026001,13.409003 12.026001,16.145027 12.026001,16.685005 12.026001,20.242991C11.39801,19.958018 10.548004,20.037974 9.8200073,20.518015 8.7900085,21.19697 8.3950195,22.417002 8.9400024,23.242993 9.4840088,24.068981 10.761017,24.188 11.791016,23.508007 12.678009,22.924021 13.091003,21.940012 12.843018,21.149973L12.843018,16.602974 19.821014,15.89698 19.821014,19.818003C19.186005,19.492991 18.298004,19.560007 17.541992,20.057017 16.511993,20.737986 16.117004,21.95698 16.661011,22.784006 17.205994,23.609997 18.483002,23.727978 19.513,23.049023 20.292999,22.534983 20.708008,21.711008 20.627014,20.982004 20.634003,20.948008 20.638,20.911997 20.638,20.875986L20.638,15.815009z M0,10.903997L32,10.903997 32,25.536999 0,25.536999z M0,0L12.890991,0 12.890991,3.2959609 32,3.2959609 32,7.2860138 0,7.2860138 0,3.948976 0,3.2959609z"
                        Background="Gray"
                        Command="{Binding SelectEmergencyAudioFileCommand}"
                        Style="{DynamicResource RoundButtons}" />
                    <TextBox
                        Width="200"
                        Height="30"
                        Padding="20,0,0,0"
                        VerticalContentAlignment="Center"
                        Background="White"
                        FontWeight="Bold"
                        IsManipulationEnabled="False"
                        Text="{Binding UserSet.EmergencyAudioFileLocation}"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto" />
                    <Button
                        Width="100"
                        Margin="-53,0,0,-13"
                        HorizontalAlignment="Center"
                        extensions:Extensions.Icon="M0,0L22.652,15.996998 0,31.999996z"
                        Background="Gray"
                        Command="{Binding PlayEmergencyAudioFileCommand}"
                        Style="{DynamicResource RoundButtons}" />
                </StackPanel>

            </StackPanel>
        </Border>

        <Border
            Grid.Row="1"
            Background="MintCream"
            BorderBrush="LightGray"
            BorderThickness="0,0,1,0">
            <StackPanel Grid.Row="2" VerticalAlignment="Center">
                <Path
                    Width="50"
                    Data="M16.131903,6.1279871L18.42993,18.972005 8.4308179,22.795001 14.344881,17.034995z M15.749894,9.7497832E-10L15.821902,9.7497832E-10 15.902896,9.7497832E-10 15.907901,9.7497832E-10C16.209906,-2.292345E-07,16.525904,-2.292345E-07,16.878905,0.050994413L16.88391,0.050994413C17.102906,0.050994618,17.327914,0.050994618,17.54192,0.1019893L17.720923,0.1019893C20.457951,0.40798905,23.07297,1.4289846,25.283991,3.0109844L26.269993,3.7250039 27.597035,1.7349845 28.312039,5.6650054 28.879031,8.8289745 25.264002,8.624995 21.877949,8.4209849 23.812968,6.6339991 22.556973,5.81799C21.06596,4.8479893,19.344933,4.1849949,17.582922,3.9809849L16.004902,3.8789951 15.877902,3.8789951C12.619857,3.9299903 9.5658391,5.2059905 7.2878001,7.5529744 5.0057786,9.9009645 3.7647682,12.962975 3.7997723,16.228965 3.8667744,22.862994 9.3358262,28.272965 15.999897,28.272965L16.1229,28.272965C19.38595,28.272965 22.434962,26.946 24.716999,24.649005 27.000012,22.301959 28.241022,19.24001 28.205042,15.97396 28.205042,15.717978 28.190028,15.462973 28.169031,15.207968L31.851076,13.830955C31.943058,14.49398 31.994053,15.157005 31.999058,15.821006 32.04508,20.107991 30.421038,24.138995 27.429034,27.201005 24.43599,30.211989 20.432957,31.947951 16.163901,31.998L15.994892,31.998C11.756856,31.998 7.7628115,30.313979 4.7447742,27.354996 1.7267525,24.394 0.041737223,20.41396 0.00073657172,16.126975 -0.060268851,9.7480113 3.672772,3.9809851 9.5098232,1.3779897L9.6218398,1.3269949 9.6728347,1.276C11.592853,0.45999097,13.635874,0.050994618,15.749894,9.7497832E-10z"
                    Fill="Black"
                    Stretch="Uniform" />
                <TextBlock
                    Height="20"
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Text="{Binding Global.AppLang.RepeatEmergency}" />
                <CheckBox
                    Height="20"
                    HorizontalAlignment="Center"
                    Content="{Binding Global.AppLang.EnableRepeat}"
                    Foreground="Green"
                    IsChecked="{Binding UserSet.RepeatEmergency}"
                    Style="{DynamicResource SliderCheckBox}" />
            </StackPanel>
        </Border>
        <Border
            Grid.Row="1"
            Grid.Column="1"
            Background="GhostWhite" />

        <Ellipse
            Grid.RowSpan="10"
            Grid.ColumnSpan="10"
            Width="100"
            Height="100"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Fill="White"
            Stroke="LightGray"
            StrokeThickness="1" />
        <Button
            Grid.RowSpan="10"
            Grid.ColumnSpan="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            extensions:Extensions.Icon="{DynamicResource EmergencyPath}"
            Background="#FF597ED8"
            Command="{Binding SaveSettingsCommand}"
            Content="{Binding Global.AppLang.Save}"
            FontSize="14"
            Foreground="#FF597ED8"
            Style="{DynamicResource RoundButtons}" />
